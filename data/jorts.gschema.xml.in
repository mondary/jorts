<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema path="@APP_PATH@/" id="@APP_ID@">
		<key name="scribbly-mode-active" type="b">
			<default>false</default>
			<summary>Change font to an illegible one</summary>
			<description>Whether to change font to an illegible one for unfocused sticky notes, for privacy</description>
		</key>
		<key name="hide-bar" type="b">
			<default>false</default>
			<summary>Hide actionbar</summary>
			<description>Whether to hide the actionbar and its buttons</description>
		</key>
		<key name="list-item-start" type="s">
			<default>" • "</default>
			<summary>Hide actionbar</summary>
			<description>Whether to hide the actionbar and its buttons</description>
		</key>
		<key name="accel-new" type="s">
			<default>"&lt;Control&gt;n"</default>
			<summary>Shortcut for new note</summary>
		</key>
		<key name="accel-delete" type="s">
			<default>"&lt;Control&gt;w"</default>
			<summary>Shortcut for delete note</summary>
		</key>
		<key name="accel-toggle-list" type="s">
			<default>"&lt;Shift&gt;F12"</default>
			<summary>Shortcut for toggle list</summary>
		</key>
	</schema>
</schemalist>
